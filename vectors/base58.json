  {
    "id": "base58-leading-zeros",
    "mode": "base58",
    "description": "Leading zero bytes map to leading \"1\" characters one-for-one.",
    "input": {
      "base58": "11Ldp",
      "as": "bytes"
    },
    "expected": {
      "hex": "0000010203"
    }
  },
  {
    "id": "base58-single-zero-byte",
    "mode": "base58",
    "description": "A single zero byte encodes as \"1\".",
