  {
    "id": "pda-curve-y-max",
    "mode": "pda",
    "description": "Invalid point encoding: all bytes 0xff (y = 2^255-1 after masking the sign bit, y >= p).",
    "input": {
      "op": "isOnCurve",
      "bytes": "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff"
    },
    "expected": {
      "onCurve": false
    }
  },
  {
    "id": "pda-curve-y-equals-p-minus-1",
    "mode": "pda",
    "description": "Canonical but off-curve encoding: y = p-1 with sign bit clear. Reference result pinned from @solana/web3.js isOnCurve: true.",
    "input": {
      "op": "isOnCurve",
      "bytes": "ecffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff7f"
    },
    "expected": {
      "onCurve": true
    }
  },
  {
    "id": "pda-curve-y-equals-1",
