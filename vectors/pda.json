  {
    "id": "pda-curve-y-equals-p",
    "mode": "pda",
    "description": "Invalid point encoding: y = p (non-canonical, must not decode as a curve point). Little-endian bytes of 2^255-19.",
    "input": {
      "op": "isOnCurve",
      "bytes": "edffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff7f"
    },
    "expected": {
      "onCurve": false
