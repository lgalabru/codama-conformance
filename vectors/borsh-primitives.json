  {
    "id": "borsh-shortu16-alias-accepted",
    "mode": "borsh",
    "description": "Non-canonical (aliased) encoding of 0 as [0x80, 0x00]. The four renderer runtimes accept aliased encodings on decode (decode-only: re-encoding produces the canonical form).",
    "input": {
      "type": "shortu16",
      "hex": "8000",
      "direction": "decode"
    },
