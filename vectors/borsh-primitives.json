  {
    "id": "borsh-option-nested-none",
    "mode": "borsh",
    "description": "option<option<u8>> none: a single 0x00.",
    "input": {
      "type": {
        "option": {
          "option": "u8"
        }
      },
      "value": null
    },
    "expected": {
      "hex": "00"
    }
  },
  {
    "id": "borsh-option-nested-some-none",
    "mode": "borsh",
    "description": "option<option<u8>> some(none): outer 0x01 flag + inner 0x00 flag. Runtimes that use null/nil as the none sentinel (e.g. python, ruby, lua) cannot construct some(none) and may skip this vector; decode-capable runtimes should still accept the bytes.",
    "input": {
      "type": {
        "option": {
          "option": "u8"
        }
      },
      "value": {
        "some": null
      }
    },
    "expected": {
      "hex": "0100"
    },
    "optional": true
  },
  {
    "id": "borsh-option-nested-some-some",
    "mode": "borsh",
    "description": "option<option<u8>> some(some(5)): two 0x01 flags + payload.",
    "input": {
      "type": {
        "option": {
          "option": "u8"
        }
      },
      "value": {
        "some": {
          "some": 5
        }
      }
    },
    "expected": {
      "hex": "010105"
    }
  },
  {
    "id": "borsh-option-bad-flag",
    "mode": "borsh",
    "description": "Strict decoders reject option flags other than 0 and 1 (python raises). Lenient decoders (ruby/php/lua) treat any non-zero flag as some; they may skip this vector.",
    "input": {
      "type": {
        "option": "u8"
      },
      "hex": "0207",
      "direction": "decode"
    },
    "expected": {
      "error": true
    },
    "optional": true
  },
